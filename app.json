{
  "expo": {
    "name": "Selene Sleep App",
    "slug": "selene-sleep-app",
    "version": "0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "selenesleepapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/selene_splash_1024.png",
      "resizeMode": "cover",
      "backgroundColor": "#050017"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yogawakeup.selene",
      "buildNumber": "6",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./firebase/google-services.json",
      "package": "com.yogawakeup.selene",
      "versionCode": 6,
      "useNextNotificationsApi": true
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "551c9705-a46f-4284-a38d-1b896be26ff6"
      }
    },
    "owner": "selene-sleep-app"
  }
}
