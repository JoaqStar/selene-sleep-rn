{
  "expo": {
    "name": "Selene Sleep App",
    "slug": "selene-sleep-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/selene_logo_moon.png",
    "scheme": "selenesleepapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/selene_splash_moon.png",
      "resizeMode": "cover",
      "backgroundColor": "#0D0014"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yogawakeup.selene",
      "buildNumber": "14",
      "usesAppleSignIn": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "LSApplicationQueriesSchemes": [
          "instagram",
          "tiktok",
          "snssdk1233",
          "fb",
          "twitter",
          "x-twitter",
          "youtube",
          "vnd.youtube",
          "linkedin",
          "reddit",
          "pinterest"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/selene_logo_moon.png",
        "backgroundColor": "#ffffff"
      },
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "googleServicesFile": "./firebase/google-services.json",
      "package": "com.yogawakeup.selene",
      "versionCode": 7,
      "useNextNotificationsApi": true
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-notifications",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "551c9705-a46f-4284-a38d-1b896be26ff6"
      }
    },
    "owner": "selene-sleep-app"
  }
}
